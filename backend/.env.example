# Database Configuration
# PostgreSQL connection string
# Format: postgres://user:password@host:port/database?sslmode=disable
# For local dev with devcontainer: postgres://timesplace:timesplace@localhost:5432/timesplace?sslmode=disable
# For local dev with devcontainer (from inside container): postgres://timesplace:timesplace@postgres:5432/timesplace?sslmode=disable
DATABASE_URL=postgres://timesplace:timesplace@localhost:5432/timesplace?sslmode=disable

# Authentication Secrets
# Generate strong random strings for production (e.g., using: openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-key-change-in-production
REFRESH_TOKEN_SECRET=your-refresh-token-secret-key-change-in-production

# Server Configuration
# Port for the backend API server
# Default: 8080
PORT=8080

# Logging
# Options: debug, info, warn, error
LOG_LEVEL=debug

# Cookie Configuration (for refresh tokens)
# Domain for cookies (leave empty for same-origin, or set to .yourdomain.com for subdomain support)
COOKIE_DOMAIN=

# Require HTTPS for cookies (true in production, false in local dev)
COOKIE_SECURE=false

# SameSite cookie attribute (lax, strict, or none)
# Use 'lax' for most cases, 'none' requires COOKIE_SECURE=true
COOKIE_SAME_SITE=lax

# Free-tier venue limit (max venues per owner; default 2)
FREE_TIER_MAX_VENUES=2
